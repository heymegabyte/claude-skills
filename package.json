{
  "name": "@heymegabyte/claude-skills",
  "version": "7.2.1",
  "description": "14-category autonomous product-building OS for AI coding tools. One-line prompts → deployed products on Cloudflare Workers.",
  "author": {
    "name": "Brian Zalewski",
    "url": "https://megabyte.space"
  },
  "type": "module",
  "homepage": "https://claude.megabyte.space",
  "repository": {
    "type": "git",
    "url": "https://github.com/heymegabyte/claude-skills.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "bin": {
    "emdash-cost-check": "bin/emdash-cost-check",
    "emdash-quick-lint": "bin/emdash-quick-lint",
    "emdash-secret-scan": "bin/emdash-secret-scan"
  },
  "exports": {
    ".": "./_router.md",
    "./conventions": "./CONVENTIONS.md",
    "./profiles": "./SKILL_PROFILES.md"
  },
  "scripts": {
    "prepare": "bash bin/install-hooks.sh",
    "lint": "bash bin/lint-all.sh",
    "lint:json": "bash bin/lint-all.sh --json",
    "check:urls": "bash bin/check-doc-urls.sh",
    "check:urls:json": "bash bin/check-doc-urls.sh --json",
    "check:pricing": "bash bin/check-pricing.sh",
    "check:pricing:json": "bash bin/check-pricing.sh --json",
    "check:agent-routing": "bash bin/check-agent-routing.sh",
    "check:agent-routing:json": "bash bin/check-agent-routing.sh --json",
    "check:pack-frontmatter": "bash bin/check-pack-frontmatter.sh",
    "check:pack-frontmatter:json": "bash bin/check-pack-frontmatter.sh --json",
    "check:agent-fallback": "bash bin/check-agent-fallback.sh",
    "check:agent-fallback:json": "bash bin/check-agent-fallback.sh --json",
    "check:deprecated-models": "bash bin/check-deprecated-models.sh",
    "check:deprecated-models:json": "bash bin/check-deprecated-models.sh --json",
    "check:skill-required-fields": "bash bin/check-skill-required-fields.sh",
    "check:skill-required-fields:json": "bash bin/check-skill-required-fields.sh --json",
    "check:skill-pack-claim": "bash bin/check-skill-pack-claim.sh",
    "check:skill-pack-claim:json": "bash bin/check-skill-pack-claim.sh --json",
    "check:skill-submodules": "bash bin/check-skill-submodules.sh",
    "check:skill-submodules:json": "bash bin/check-skill-submodules.sh --json",
    "check:ci": "bash bin/check-ci-status.sh",
    "check:ci:wait": "bash bin/check-ci-status.sh --wait",
    "check:ci:json": "bash bin/check-ci-status.sh --json",
    "check:doc-counts": "bash bin/check-doc-counts.sh",
    "check:doc-counts:json": "bash bin/check-doc-counts.sh --json",
    "health": "bash bin/lint-all.sh && bash bin/check-ci-status.sh",
    "lint:fix": "npx --yes markdownlint-cli2@^0.18.1 --fix '**/*.md' && npx --yes prettier@3 --config .prettierrc.json --write '**/*.{json,jsonc,yml,yaml}' && shfmt -i 2 -ci -bn -w bin/*.sh bin/lib/*.sh scripts/*.sh",
    "validate": "bash scripts/validate-skills.sh && node scripts/validate-packs.mjs",
    "validate:packs": "node scripts/validate-packs.mjs",
    "sha-pin": "node scripts/sha-pin-actions.mjs .github/workflows/*.yml",
    "sha-pin:check": "node scripts/sha-pin-actions.mjs --check .github/workflows/*.yml"
  },
  "keywords": [
    "claude-code",
    "claude-skills",
    "ai-skills",
    "agent-skills",
    "codex-skills",
    "cursor-rules",
    "copilot-instructions",
    "autonomous",
    "product-building",
    "cloudflare-workers",
    "angular",
    "hono",
    "saas",
    "ai-native",
    "agents",
    "agentskills"
  ],
  "files": [
    "01-*/**",
    "02-*/**",
    "03-*/**",
    "04-*/**",
    "05-*/**",
    "06-*/**",
    "07-*/**",
    "08-*/**",
    "09-*/**",
    "10-*/**",
    "11-*/**",
    "12-*/**",
    "13-*/**",
    "14-*/**",
    "agents/**",
    "templates/**",
    "scripts/**",
    "bin/**",
    "CONVENTIONS.md",
    "SKILL_PROFILES.md",
    "_router.md",
    "llms.txt",
    "llms-full.txt",
    "AGENTS.md",
    ".cursorrules",
    ".windsurfrules",
    ".clinerules",
    ".rules",
    ".augment-guidelines",
    ".aider-conventions.md",
    ".github/copilot-instructions.md",
    ".amazonq/**",
    ".junie/**",
    ".trae/**",
    ".tabnine/**",
    ".kilo/**",
    ".roo/**",
    ".continue/**",
    ".agents/**",
    ".claude-plugin/**",
    ".cursor/**",
    ".windsurf/**",
    ".augment/**",
    ".openhands/**",
    ".aiassistant/**",
    ".kiro/**",
    ".void/**",
    ".bolt/**",
    ".devin/**",
    ".goose/**",
    "QODO.MD",
    ".github/instructions/**",
    "GEMINI.md",
    "AMP.md",
    "CODEX.md",
    "jsr.json",
    "replit.md",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
