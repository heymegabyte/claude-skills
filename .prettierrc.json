{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "endOfLine": "lf",
  "bracketSpacing": true,
  "overrides": [
    {
      "files": ["*.json", "*.jsonc", "*.yml", "*.yaml"],
      "options": {
        "singleQuote": false
      }
    }
  ]
}
